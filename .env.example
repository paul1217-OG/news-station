# ===== LINE Messaging API =====
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# ===== OpenAI (選用) =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== GitHub PDF 上傳（v3 新增）=====
# 用途：每日 PDF 報告自動推到 GitHub repo 的 reports/ 資料夾
# GITHUB_TOKEN：到 https://github.com/settings/tokens?type=beta 申請 Fine-grained PAT
# 權限只需給 Contents: Read and write，repo 範圍選 news-station
GITHUB_TOKEN=
GITHUB_REPO=paul1217-OG/news-station

# ===== 推播設定 =====
TOPIC_WEIGHTS_TW=40
TOPIC_WEIGHTS_US=25
TOPIC_WEIGHTS_ASIA=10
TOPIC_WEIGHTS_EU=5
TOPIC_WEIGHTS_INDUSTRY=15
TOPIC_WEIGHTS_MACRO=5
MAX_NEWS_ITEMS=8
USE_ONLINE_TRANSLATE=true
DRY_RUN=false
TZ=Asia/Taipei
