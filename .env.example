# ===== LINE Messaging API =====
# 從 LINE Developers Console 取得：https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# ===== AI 摘要 (擇一即可) =====
# OpenAI API Key — 從 https://platform.openai.com/api-keys 取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude API Key (替代方案) — 從 https://console.anthropic.com 取得
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ===== 推播設定 =====
# 主題權重：台股,美股,亞股,歐股,產業,宏觀 (總和 = 100)
TOPIC_WEIGHTS_TW=40
TOPIC_WEIGHTS_US=25
TOPIC_WEIGHTS_ASIA=10
TOPIC_WEIGHTS_EU=5
TOPIC_WEIGHTS_INDUSTRY=15
TOPIC_WEIGHTS_MACRO=5

# 一次推播幾條新聞
MAX_NEWS_ITEMS=8

# 是否啟用 dry-run 模式（不實際發送 LINE，只產出 JSON 檔）
DRY_RUN=true
